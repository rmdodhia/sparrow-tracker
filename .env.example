AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_API_VERSION=2024-10-21

# Database — leave blank for SQLite (local dev), set for Azure SQL (production)
# AZURE_SQL_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=tcp:your-server.database.windows.net,1433;Database=your-db;Uid=your-user;Pwd=your-password;Encrypt=yes;TrustServerCertificate=no;

# Microsoft Graph email (production) — set these to use Graph API
# GRAPH_CLIENT_ID=your-app-registration-client-id
# GRAPH_CLIENT_SECRET=your-client-secret
# GRAPH_TENANT_ID=your-tenant-id
# GRAPH_USER_EMAIL=your-mailbox@your-domain.com

# Email Ingestion (IMAP — legacy, used when Graph is not configured)
# IMAP_HOST=imap.example.com
# IMAP_PORT=993
# IMAP_USER=your-inbox@example.com
# IMAP_PASS=your-password
# IMAP_FOLDER=INBOX
# IMAP_DONE_FOLDER=Processed
